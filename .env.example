# --- Cloudinary (almacenamiento de imagenes y videos) ---
# Se obtienen en https://cloudinary.com/console (Dashboard).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Acceso al panel admin ---
ADMIN_USER=admin
ADMIN_PASSWORD=carneselrey123

# --- Seguridad de los tokens (JWT) ---
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Opcional ---
# Puerto local (Railway lo inyecta automaticamente en produccion).
PORT=8000
# Para persistir SQLite en Railway montando un volumen, por ejemplo:
